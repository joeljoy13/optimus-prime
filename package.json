{
  "name": "prime-orbit",
  "version": "1.0.0",
  "description": "Deterministic prime-transformation password generator with cryptographic safety and bounded indexing.",
  "main": "electron-dist/electron/main.js",
  "author": "Prime Orbit",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:renderer": "vite",
    "dev:electron:build": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 file:electron-dist/electron/main.js && node electron/dev-runner.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "jest --runInBand",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run typecheck && npm run test && npm run build:renderer && npm run build:electron",
    "predist": "npm run build",
    "dist": "electron-builder --win",
    "dist:all": "npm run build && electron-builder",
    "make-exe": "npm install && npm run build && npm run dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "jest": "^29.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
