{
  "appId": "com.primeorbit.desktop",
  "productName": "Prime Orbit",
  "copyright": "Copyright © 2026 Prime Orbit",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron-dist/**/*",
    "package.json"
  ],
  "asar": true,
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "Prime-Orbit-${version}-Setup.${ext}"
  },
  "mac": {
    "target": [
      "dmg"
    ],
    "category": "public.app-category.utilities"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true
  }
}
